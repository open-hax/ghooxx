{:source-paths ["src"]

 :dependencies
 []

 :builds
 {:plugin
  {:target :esm
   :output-dir "dist"
   :modules {:plugin {:exports {:default ghooxx.plugin.entry/GhooxxPlugin}}}
   :js-options {:js-provider :import}
   :compiler-options
   {:output-feature-set :es-next}}

  :server
  {:target :node-script
   :output-dir "dist"
   :output-to "dist/server.cjs"
   :main ghooxx.server.main/main
   :compiler-options
   {:output-feature-set :es-next}}}}
