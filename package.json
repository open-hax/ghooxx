{
  "name": "@open-hax/ghooxx",
  "version": "0.0.1",
  "description": "GitHub webhook dispatcher and OpenCode notifier",
  "private": false,
  "license": "GPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "shadow-cljs release plugin server",
    "watch:plugin": "shadow-cljs watch plugin",
    "watch:server": "shadow-cljs watch server",
    "server:dev": "shadow-cljs server server",
    "plugin:copy": "mkdir -p .opencode/plugins && cp dist/plugin.js .opencode/plugins/ghooxx.js",
    "plugin:link": "mkdir -p .opencode/plugins && ln -sf $(pwd)/dist/plugin.js .opencode/plugins/ghooxx.js",
    "start": "node dist/server.cjs",
    "test": "echo 'no tests yet'",
    "clean": "rm -rf dist .shadow-cljs"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.0",
    "@opencode-ai/plugin": "^1.14.41",
    "fastify": "^5.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "shadow-cljs": "^3.4.11"
  }
}
